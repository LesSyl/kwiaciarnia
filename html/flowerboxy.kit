<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flower boxy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400..700&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/684c9ec5ef.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/dist/css/main.min.css">
</head>

<body>
    <!-- @include "nav.kit" -->
    <main>
        <section class="hero">
            <div class="wrapper">
                <div class="hero__box">
                    <div class="hero__content">
                        <p class="hero__subtitle">Flower Boxy</p>

                        <h1 class="hero__title">
                            Kwiaty w wyjątkowej oprawie
                        </h1>

                        <p class="hero__text">
                            Eleganckie kompozycje kwiatowe zamknięte w ozdobnych
                            pudełkach. Idealne na prezent, rocznicę, urodziny
                            i każdą wyjątkową okazję.
                        </p>

                    </div>
                </div>
            </div>
        </section>

        <section class="section-products section-padding" id="collection">
            <div class="wrapper">
                <div class="section-heading">
                    <h2>Nasze Flower Boxy</h2>
                    <div class="section-heading__decor"></div>
                </div>

                <div class="products">
                    <div class="product-card">
                        <img src="/dist/img/bouquet/Flower Boxy.png" alt="Delikatny Róż" class="product-card__img">

                        <div class="product-card__body">
                            <h3 class="product-card__name">Delikatny Róż</h3>
                            <p class="product-card__price">189 zł</p>

                            <button class="product-card__btn add-to-cart">
                                Dodaj do koszyka
                            </button>
                        </div>
                    </div>
                    <div class="product-card">
                        <img src="/dist/img/bouquet/Flower Boxy.png" alt="Biała Elegancja" class="product-card__img">

                        <div class="product-card__body">
                            <h3 class="product-card__name">Biała Elegancja</h3>
                            <p class="product-card__price">199 zł</p>

                            <button class="product-card__btn add-to-cart">
                                Dodaj do koszyka
                            </button>
                        </div>
                    </div>
                    <div class="product-card">
                        <img src="/dist/img/bouquet/Flower Boxy.png" alt="Lawendowe marzenie" class="product-card__img">

                        <div class="product-card__body">
                            <h3 class="product-card__name">Lawendowe marzenie</h3>
                            <p class="product-card__price">209 zł</p>

                            <button class="product-card__btn add-to-cart">
                                Dodaj do koszyka
                            </button>
                        </div>
                    </div>
                    <div class="product-card">
                        <img src="/dist/img/bouquet/Flower Boxy.png" alt="Klasyczna czerwień" class="product-card__img">

                        <div class="product-card__body">
                            <h3 class="product-card__name">Klasyczna czerwień</h3>
                            <p class="product-card__price">229 zł</p>

                            <button class="product-card__btn add-to-cart">
                                Dodaj do koszyka
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="section-benefits section-padding">
            <div class="wrapper">
                <div class="section-heading">
                    <h2>Dla kogo są Flower Boxy?</h2>
                    <div class="section-heading__decor"></div>
                </div>

                <div class="section-benefits__cards">
                    <div class="section-benefits__card">
                        <i class="fa-solid fa-gift"></i>
                        <h3>Na prezent</h3>
                        <p>Idealne na urodziny, imieniny i rocznice.</p>
                    </div>

                    <div class="section-benefits__card">
                        <i class="fa-regular fa-heart"></i>
                        <h3>Dla bliskich</h3>
                        <p>Piękny sposób na wyrażenie uczuć.</p>
                    </div>

                    <div class="section-benefits__card">
                        <i class="fa-solid fa-house"></i>
                        <h3>Do domu</h3>
                        <p>Stylowa dekoracja każdego wnętrza.</p>
                    </div>

                    <div class="section-benefits__card">
                        <i class="fa-solid fa-briefcase"></i>
                        <h3>Do firmy</h3>
                        <p>Elegancki upominek dla klientów i partnerów.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="flowerbox-faq section-padding">
            <div class="wrapper">
                <div class="section-heading">
                    <h2>Najczęściej zadawane pytania</h2>
                    <div class="section-heading__decor"></div>
                </div>

                <div class="flowerbox-faq__accordion">

                    <div class="flowerbox-faq__item">
                        <button class="flowerbox-faq__question">
                            <span>Jak długo utrzymują się flower boxy?</span>
                            <i class="fa-solid fa-plus"></i>
                        </button>

                        <div class="flowerbox-faq__answer">
                            <p>
                                Przy odpowiedniej pielęgnacji flower box może zachować świeżość
                                nawet przez kilkanaście dni.
                            </p>
                        </div>
                    </div>

                    <div class="flowerbox-faq__item">
                        <button class="flowerbox-faq__question">
                            <span>Czy flower box wymaga podlewania?</span>
                            <i class="fa-solid fa-plus"></i>
                        </button>

                        <div class="flowerbox-faq__answer">
                            <p>
                                Tak, jednak znacznie rzadziej niż klasyczny bukiet.
                            </p>
                        </div>
                    </div>

                    <div class="flowerbox-faq__item">
                        <button class="flowerbox-faq__question">
                            <span>Czy mogę zamówić własną kompozycję?</span>
                            <i class="fa-solid fa-plus"></i>
                        </button>

                        <div class="flowerbox-faq__answer">
                            <p>
                                Oczywiście. Tworzymy również indywidualne kompozycje według
                                Twoich preferencji.
                            </p>
                        </div>
                    </div>

                    <div class="flowerbox-faq__item">
                        <button class="flowerbox-faq__question">
                            <span>Czy realizujecie dostawy tego samego dnia?</span>
                            <i class="fa-solid fa-plus"></i>
                        </button>

                        <div class="flowerbox-faq__answer">
                            <p>
                                Tak, dla zamówień złożonych do godziny 14:00.
                            </p>
                        </div>
                    </div>

                </div>

            </div>
        </section>
    </main>

    <!-- @include "footer.kit"-->
    <script src="/dist/js/main.min.js"></script>
</body>


</html>