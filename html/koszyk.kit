<!DOCTYPE html>
<html lang="pl">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Koszyk | Bloom Kwiaciarnia</title>

	<link rel="stylesheet" href="/dist/css/main.min.css">
	<script src="https://kit.fontawesome.com/684c9ec5ef.js" crossorigin="anonymous"></script>
</head>

<body>

	<!-- @include "nav.kit" -->

	<main>
		<section class="cart-page">
			<div class="wrapper">
				<h1 class="cart-page__title">Twój koszyk</h1>

				<div class="cart-page__content">
					<div class="cart-page__items"></div>

					<div class="cart-page__summary">
						<h2>Podsumowanie</h2>
						<p>Razem: <span class="cart-page__total">0 zł</span></p>

						<a href="kontakt.html" class="cart-page__btn">
							Przejdź do zamówienia
						</a>

						<button class="cart-page__clear">
							Wyczyść koszyk
						</button>
					</div>
				</div>
			</div>
		</section>
	</main>

	<!-- @include "footer.kit" -->

	<script src="/dist/js/main.min.js"></script>
</body>

</html>