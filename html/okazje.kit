<!DOCTYPE html>
<html lang="pl">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Okazje</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link
		href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
		rel="stylesheet">
	<script src="https://kit.fontawesome.com/684c9ec5ef.js" crossorigin="anonymous"></script>
	<link rel="stylesheet" href="/dist/css/main.min.css">
</head>

<body>
	<!-- @include "nav.kit" -->


	<section class="occasions-hero">
		<div class="wrapper">
			<div class="occasions-hero__box">
				<div class="occasions-hero__content">
					<h1 class="occasions-hero__title">Okazje</h1>
					<p class="occasions-hero__text">
						Znajdź idealny bukiet na każdą wyjątkową chwilę.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="occasions-page section-padding">
		<div class="wrapper">
			<div class="section-heading">
				<h2>Wybierz okazję</h2>
				<div class="section-heading__decor"></div>
			</div>

			<div class="occasions-page__cards">
				<a href="#" class="occasion-card">
					<img src="/dist/img/bouquet/bukiet na dzień matki.png" alt="Bukiet na urodziny">
					<div class="occasion-card__body">
						<i class="fa-solid fa-cake-candles"></i>
						<h3>Urodziny</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/bouquet/bukiet na rocznicę.png" alt="Bukiet na rocznicę">
					<div class="occasion-card__body">
						<i class="fa-regular fa-heart"></i>
						<h3>Rocznica</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/bouquet/bukiet na urodziny.png" alt="Bukiet na Dzień Matki">
					<div class="occasion-card__body">
						<i class="fa-solid fa-seedling"></i>
						<h3>Dzień Matki</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/bouquet/bukiet na ślub.png" alt="Bukiet ślubny">
					<div class="occasion-card__body">
						<i class="fa-regular fa-heart"></i>
						<h3>Ślub</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/bouquet/bukiet pogrzebowy.png" alt="Bukiet pogrzebowy">
					<div class="occasion-card__body">
						<i class="fa-solid fa-church"></i>
						<h3>Pogrzeb</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/bouquet/Flower Boxy.png" alt="Bukiet dla niej">
					<div class="occasion-card__body">
						<i class="fa-regular fa-heart"></i>
						<h3>Dla niej</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/bouquet/bukiet dla niego.png" alt="Bukiet dla niego">
					<div class="occasion-card__body">
						<i class="fa-solid fa-user-tie"></i>
						<h3>Dla niego</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="../dist/img/bouquet/bukiet na dzień kobiet.png" alt="Bukiet na Dzień Kobiet">
					<div class="occasion-card__body">
						<i class="fa-solid fa-venus"></i>
						<h3>Dzień Kobiet</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="../dist/img/bouquet/" alt="Bukiet z gratulacjami">
					<div class="occasion-card__body">
						<i class="fa-solid fa-graduation-cap"></i>
						<h3>Zakończenie roku / Gratulacje</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/occasions/dekoracje-kosciolow.jpg" alt="Dekoracje kościołów">
					<div class="occasion-card__body">
						<i class="fa-solid fa-church"></i>
						<h3>Dekoracje kościołów</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/occasions/komunia.jpg" alt="Dekoracje na Komunię Świętą">
					<div class="occasion-card__body">
						<i class="fa-solid fa-wine-glass"></i>
						<h3>Komunia Święta</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/occasions/narodziny.jpg" alt="Bukiet z okazji narodzin dziecka">
					<div class="occasion-card__body">
						<i class="fa-solid fa-baby"></i>
						<h3>Narodziny dziecka</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/occasions/nowy-dom.jpg" alt="Bukiet na nowy dom">
					<div class="occasion-card__body">
						<i class="fa-solid fa-house"></i>
						<h3>Nowy dom</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/occasions/powrot-do-zdrowia.jpg" alt="Bukiet na powrót do zdrowia">
					<div class="occasion-card__body">
						<i class="fa-regular fa-face-smile"></i>
						<h3>Powrót do zdrowia</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/occasions/przepraszam.jpg" alt="Bukiet na przeprosiny">
					<div class="occasion-card__body">
						<i class="fa-solid fa-hand-holding-heart"></i>
						<h3>Przepraszam</h3>
					</div>
				</a>

				<a href="#" class="occasion-card">
					<img src="/dist/img/occasions/bez-okazji.jpg" alt="Bukiet bez okazji">
					<div class="occasion-card__body">
						<i class="fa-regular fa-sun"></i>
						<h3>Bez okazji</h3>
					</div>
				</a>
			</div>

			<div class="occasions-page__cta">
				<div>
					<i class="fa-solid fa-bouquet"></i>
					<p>
						<strong>Nie znalazłeś odpowiedniej okazji?</strong>
						<span>Stwórz bukiet na zamówienie dopasowany do Twoich potrzeb.</span>
					</p>
				</div>

				<a href="#contact">Kontakt z nami</a>
			</div>
		</div>
	</section>


	<!-- @include "footer.kit"-->
	 <script src="/dist/js/main.min.js"></script>
</body>


</html>